@model IEnumerable<Personal_Info_Management_System.Models.PersonalInfo>
<h2 class="mb-3">Personal Information List</h2>

<a asp-action="Create" class="btn btn-primary mb-3">
    Add New Record
</a>

<table id="personalTable" class="table table-bordered table-striped">

    <thead class="table-dark">
        <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Gender</th>
            <th>Nationality</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.FirstName</td>
                <td>@item.LastName</td>
                <td>@item.Email</td>
                <td>@item.PhoneNumber</td>
                <td>@item.Gender</td>
                <td>@item.Nationality</td>

                <td>

                    <a asp-action="Edit"
                       asp-route-id="@item.Id"
                       class="btn btn-warning btn-sm">
                        Edit
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@item.Id"
                       class="btn btn-danger btn-sm">
                        Delete
                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>

@section Scripts {

    <script>

        $(document).ready(function () {

            $('#personalTable').DataTable({
                pageLength: 10
            });

        });

    </script>

}